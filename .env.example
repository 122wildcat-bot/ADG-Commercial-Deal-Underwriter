# Required in production
JWT_SECRET=change-this-to-a-long-random-string
ADMIN_EMAIL=yourrealtoradamd@gmail.com
ADMIN_PASSWORD=change-this-to-a-long-random-string

# Optional — overrides for the data directory. Resolution order:
#   DATA_DIR → RAILWAY_VOLUME_MOUNT_PATH → /data (on Railway) → cwd (local dev)
# Mount a Railway Volume at /data or every deal is wiped on redeploy.
# DATA_DIR=

# Your deployed app URL (set after Railway gives you a domain)
APP_URL=https://your-app.up.railway.app

# Server port (Railway sets PORT automatically)
PORT=5000

# CRM bridge (Phase 1 ships a typed mock; live integration is a later additive PR)
# When CRM_MODE=mock (default), no live calls are made; the client returns synthetic
# responses so the rest of the app can be developed against the real interface.
CRM_MODE=mock
CRM_BASE_URL=https://adg-crm-production.up.railway.app
CRM_API_KEY=change-this-to-a-long-random-string

# Optional AI assist (Phase 3 — degrade gracefully when unset)
# Default model: claude-sonnet-4-6 (latest: opus 4.7, sonnet 4.6, haiku 4.5)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
